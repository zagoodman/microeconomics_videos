   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      ". * Data prep functions\n",
      ". \n",
      ". foreach v in clean_data get_idyearlevel merge_winter_gpa ///\n",
      ">     merge_dem clean_dem get_std_units {\n",
      "  2.     capture program drop `v'\n",
      "  3. }\n",
      "\n",
      ". \n",
      ". * define data clean function common to all dfs\n",
      ". program clean_data\n",
      "  1.     capture drop arm\n",
      "  2.     gen arm = treated + toberandomized\n",
      "  3.     drop toberandomized\n",
      "  4.     drop if mi(mid1score) // did not start experiment\n",
      "  5.     label define arm 0 \"Above median\" 1 \"Control\" 2 \"Treated\"\n",
      "  6.     label values arm arm\n",
      "  7.     capture drop y2019\n",
      "  8.     gen y2019 = year == 2019\n",
      "  9.     capture drop bothpairs\n",
      " 10.     gen pairyear = year * 1000 + pair\n",
      " 11.     sort pair year\n",
      " 12.     foreach v in assigned_grade mid2score finalscore {\n",
      " 13.         gen bothpairs_`v' = !mi(`v')\n",
      " 14.         by pair year: ereplace bothpairs_`v' = sum(bothpairs_`v')\n",
      " 15.         replace bothpairs_`v' = bothpairs_`v' >= 2\n",
      " 16.     }\n",
      " 17.     rename (bothpairs_mid2 bothpairs_final) (bothpairs_mid2 bothpairs_fina\n",
      "> l)\n",
      " 18.     replace mathquiz = 0 if mi(mathquiz)\n",
      " 19.     end\n",
      "\n",
      ". \n",
      ". * define function that loads student-year level data\n",
      ". program get_idyearlevel\n",
      "  1.     import delimited ./data/generated/id-year_level_data.csv, clear varnam\n",
      "> es(1)\n",
      "  2.     duplicates drop\n",
      "  3.     clean_data\n",
      "  4.     end\n",
      "\n",
      ". \n",
      ". * merge gpa/units/class data from subsequent quarter\n",
      ". program merge_winter_gpa\n",
      "  1.     preserve\n",
      "  2.     import delimited ./data/generated/dem_nextquarter.csv, clear varnames(\n",
      "> 1)\n",
      "  3.     local renamevars units_letter units_pnp units_w ///\n",
      ">         gpa_letter gpa_letter_sansecon gpa_letter_sans100a gpa_econ_sans100a \n",
      "> ///\n",
      ">         nclass_letter nclass_np nclass_pnp nclass_p nclass_w\n",
      "  4.     keep id year `renamevars' \n",
      "  5.     foreach v in `renamevars' {\n",
      "  6.         rename `v' winter_`v'\n",
      "  7.     }\n",
      "  8.     tempfile temp\n",
      "  9.     save `temp'\n",
      " 10.     restore\n",
      " 11.     merge 1:1 id year using `temp', nogen keep(1 3) //This drops 10 studen\n",
      "> ts who appear to have dropped ECON1 before the first exam\n",
      " 12.     end\n",
      "\n",
      ". \n",
      ". * merge demographic data\n",
      ". program merge_dem\n",
      "  1.     preserve\n",
      "  2.     import delimited ./data/generated/dem_concurrent.csv, clear varnames(1\n",
      "> )\n",
      "  3.     tempfile temp\n",
      "  4.     save `temp'\n",
      "  5.     restore\n",
      "  6.     merge 1:1 id year using `temp', nogen keep(1 3) //This drops 10 studen\n",
      "> ts who appear to have dropped ECON1 before the first exam\n",
      "  7.     end\n",
      "\n",
      ". \n",
      ". * get demographic vars into binary form\n",
      ". program clean_dem\n",
      "  1.     capture drop male female othergen ///\n",
      ">         chinese latx oasian viet white othereth \n",
      "  2.     * gender\n",
      ".     gen male = gender == \"m\"\n",
      "  3.     gen female = gender == \"f\"\n",
      "  4.     gen othergen = gender == \"u\"\n",
      "  5.     * ethnicity\n",
      ".     gen chinese = ethnicity == \"Chinese/Chinese-American\"\n",
      "  6.     gen latx = ethnicity == \"Chicanx/Latinx\"\n",
      "  7.     gen oasian = ethnicity == \"All Other Asian/Asian-American\"\n",
      "  8.     gen viet = ethnicity == \"Vietnamese\"\n",
      "  9.     gen white = ethnicity == \"White/Caucasian\"\n",
      " 10.     gen othereth = !mi(ethnicity) & !(chinese | latx | oasian | viet | whi\n",
      "> te)\n",
      " 11.     gen asian = chinese + oasian + viet\n",
      " 12.     * prev cumulative gpa\n",
      ".     gen prev_cumgpa_unobs = mi(prev_cumgpa)\n",
      " 13.     replace prev_cumgpa = 0 if mi(prev_cumgpa) // prev_cumgpa is interacti\n",
      "> on of obs * gpa\n",
      " 14.     * whether pass 100A\n",
      ".     capture drop pass\n",
      " 15.     gen pass = inlist(substr(assigned_grade, 1, 1), \"A\", \"B\", \"C\", \"P\")\n",
      " 16.     replace pass = . if mi(finalscore)\n",
      " 17.     * whether pass 100B\n",
      ".     capture drop pass100b\n",
      " 18.     gen pass100b = inlist(substr(lettergrade_100b, 1, 1), \"A\", \"B\", \"C\") i\n",
      "> f !mi(lettergrade_100b)\n",
      " 19.     * whether take 100A for letter\n",
      ".     capture drop letter_option\n",
      " 20.     gen letter_option = inlist(substr(assigned_grade, 1, 1), \"A\", \"B\", \"C\"\n",
      "> , \"D\", \"F\")\n",
      " 21.     replace letter_option = . if mi(finalscore)\n",
