   "source": [
    "* get point estimates using local linear reg\n",
    "\n",
    "program drop get_rd_est\n",
    "program get_rd_est\n",
    "    args y x keepvar\n",
    "\n",
    "    preserve\n",
    "\n",
    "    * get N\n",
    "    qui keep if !mi(`keepvar')\n",
    "    qui sum `keepvar'\n",
    "    local obs = r(N)\n",
    "\n",
    "    * control\n",
    "    qui replace arm = 1 if arm == 0\n",
    "    qui keep if arm == 1\n",
    "\n",
    "    foreach v in xhat yhat sehat xat {\n",
    "        capture drop `v'\n",
    "    }\n",
    "    gen xat = 0\n",
    "    qui lpoly `y' `x', gen(xhat yhat) se(sehat) ///\n",
    "        kernel(tri) bw(0.9) degree(1) n(50) at(xat)\n",
    "    qui sum yhat\n",
    "    local meanctrl = r(mean)\n",
    "    qui sum sehat\n",
    "    local se_c = r(mean)\n",
    "\n",
    "    restore\n",
    "\n",
    "    * treatment\n",
    "    preserve\n",
    "    qui keep if !mi(`keepvar')\n",
    "    qui keep if arm == 2\n",
    "\n",
    "    foreach v in xhat yhat sehat xat {\n",
    "        capture drop `v'\n",
    "    }\n",
    "    gen xat = 0\n",
    "    qui lpoly `y' `x', gen(xhat yhat) se(sehat) ///\n",
    "        kernel(tri) bw(0.9) degree(1) n(50) at(xat)\n",
    "    qui sum yhat\n",
    "    local meantreat = r(mean)\n",
    "    local meandiff = `meantreat' - `meanctrl'\n",
    "    qui sum sehat\n",
    "    local se_t = r(mean)\n",
    "\n",
    "    * get se\n",
    "    local se = sqrt(`se_c'^2 + `se_t'^2)\n",
    "\n",
    "    * post results\n",
    "    frame post results (\"`y'\") (`obs') (`meanctrl') (`meantreat') (`meandiff') (`se')\n",
    "\n",
    "    restore\n",
    "    end\n",
    "\n",
    "get_rd_est videos_mid2_u mid1scorestd mid2scorestd\n",
    "get_rd_est mid2scorestd mid1scorestd mid2scorestd\n",
    "get_rd_est videos_final_u mid1scorestd finalscorestd\n",
    "get_rd_est finalscorestd mid1scorestd finalscorestd\n",
    "\n",
    "preserve\n",
    "keep if bothpairs_mid2 | mid1scorestd > 0\n",
    "get_rd_est videos_mid2_u mid1scorestd mid2scorestd\n",
    "get_rd_est mid2scorestd mid1scorestd mid2scorestd\n",
    "restore\n",
    "preserve\n",
    "keep if bothpairs_final | mid1scorestd > 0\n",
    "get_rd_est videos_final_u mid1scorestd finalscorestd\n",
    "get_rd_est finalscorestd mid1scorestd finalscorestd\n",
    "restore\n",
    "\n",
    "frame results: li"
   ]
  },
